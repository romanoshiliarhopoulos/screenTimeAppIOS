{
  "expo": {
    "name": "ScreenTime",
    "slug": "screentime",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D1466"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.screentimeapp.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification",
          "remote-notification",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2D1466"
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e37e483f-d68a-47ed-9b11-a5065b39edcb"
      }
    },
    "owner": "hili900",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e37e483f-d68a-47ed-9b11-a5065b39edcb"
    }
  }
}
